# ============================================================
# Senyas Web – Environment Variables
# Copy this file to .env for local development.
# On Railway, set these via the dashboard (Variables tab).
# ============================================================

# REQUIRED – Secret key for Flask sessions/cookies.
# Generate a strong one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-string

# REQUIRED for production – PostgreSQL connection URL from Railway.
# Leave blank locally to use SQLite.
DATABASE_URL=postgresql://user:password@host:5432/railway

# OPTIONAL – Set to "true" to enable Flask debug mode (never in production!)
DEBUG=false
